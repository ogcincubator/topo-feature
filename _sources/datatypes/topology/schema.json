{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Topology datatype for topo-features. Supports two reference styles: 'references' (array of string IDs) for simple positional references, and 'directed_references' (array of oriented object references with ref+orientation) for references where traversal direction matters. Exactly one of the two must be present.",
  "$defs": {
    "simpleRefs": {
      "description": "Plain string ID references (e.g. LineString referencing point nodes)",
      "properties": {
        "references": {
          "type": "array",
          "items": {
            "$ref": "bblocks://ogc.ogc-utils.iri-or-curie"
          }
        }
      },
      "required": [
        "references"
      ],
      "not": {
        "required": [
          "directed_references"
        ]
      }
    },
    "nestedRefs": {
      "description": "Plain string ID references (e.g. LineString referencing point nodes)",
      "properties": {
        "type": {
          "enum": [
            "MultiLineString",
            "Polygon",
            "Polyhedron",
            "Solid"
          ]
        },
        "references": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "$ref": "bblocks://ogc.ogc-utils.iri-or-curie"
                },
                {
                  "description": "wont check contents deeper",
                  "type": "array"
                }
              ]
            }
          }
        }
      },
      "required": [
        "references"
      ],
      "not": {
        "required": [
          "directed_references"
        ]
      }
    },
    "directedRefs": {
      "description": "Oriented (directed) references — each with 'ref' and 'orientation'. Used for Ring, Shell.",
      "properties": {
               "type": {
          "enum": [
            "Face",
            "Ring",
            "Shell",
            "Solid"
          ]
        },
        "directed_references": {
          "type": "array",
          "items": {
            "$ref": "bblocks://ogc.geo.topo.datatypes.oriented-ref"
          }
        }
      },
      "required": [
        "directed_references"
      ],
      "not": {
        "required": [
          "references"
        ]
      }
    }
  },
  "allOf": [
    {
      "oneOf": [
        {
          "$ref": "#/$defs/simpleRefs"
        },
        {
          "$ref": "#/$defs/nestedRefs"
        },
        {
          "$ref": "#/$defs/directedRefs"
        }
      ]
    },
    {
      "properties": {
        "type": {
          "type": "string"
        },
        "relationships": {
          "type": "array",
          "items": {
            "allOf": [
              {
                "$ref": "bblocks://ogc.geo.json-fg.link-role"
              },
              {
                "properties": {
                  "rel": {
                    "const": "topology"
                  }
                },
                "required": [
                  "rel"
                ]
              }
            ]
          }
        }
      },
      "required": [
        "type"
      ]
    }
  ]
}
