{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Feature with defined topology for bounding elements",
  "allOf": [
    {
      "$ref": "bblocks://ogc.geo.topo.features.topo-feature-collection#FeatureOptions"
    },
    {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "topology": {
          "$ref": "bblocks://ogc.geo.topo.datatypes.topology"
        }
      },
      "required": [
        "topology"
      ]
    }
  ]
}