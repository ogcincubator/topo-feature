{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "A Ring feature: an ordered closed loop of directed (oriented) Edge references forming a boundary. geometry must be null. Uses directed_references (not references) in its topology.",
  "allOf": [
    {
      "$ref": "bblocks://ogc.geo.topo.features.topo-feature"
    },
    {
      "properties": {
        "geometry": {
          "type": "null"
        },
        "circumference": { "type":  "number"},
        "topology": {
          "properties": {
            "type": {
              "type": "string",
              "const": "Ring"
            },
            "directed_references": {
              "type": "array",
              "description": "Ordered list of oriented Edge references forming the closed ring boundary",
              "items": {
                "$ref": "bblocks://ogc.geo.topo.datatypes.oriented-ref"
              },
              "minItems": 3
            }
          },
          "required": [
            "type",
            "directed_references"
          ],
          "not": {
            "required": [
              "references"
            ]
          }
        }
      },
      "required": [
        "topology"
      ]
    }
  ]
}
